generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  photo         String?
  role          String    @default("user")
  isBanned      Boolean   @default(false)
  isVerified    Boolean   @default(false)
  lastLoginAt   DateTime?
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trips      Trip[]
  incidents Incident[]

  @@index([email])
  @@index([createdAt])
}

model Trip {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startName    String
  endName      String
  startLon     Float
  startLat     Float
  endLon       Float
  endLat       Float
  distanceKm   Float
  durationMin  Int
  vehicleType  String   @default("driving")
  safetyScore  Int      @default(0)
  riskLevel    String   @default("low")
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([riskLevel])
}

model Incident {
  id           String   @id @default(cuid())
  reportedById String
  reportedBy   User     @relation(fields: [reportedById], references: [id], onDelete: Cascade)
  type         String
  lat          Float
  lon          Float
  description  String?
  severity     String   @default("medium")
  status       String   @default("pending")
  upvotes      Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([reportedById])
  @@index([status])
  @@index([createdAt])
  @@index([lat, lon])
}