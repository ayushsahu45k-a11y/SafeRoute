# SafeRoute Environment Variables

# Database - Use PostgreSQL in production
# For local development: postgresql://USER:PASSWORD@localhost:5432/saferoute
# For Vercel: postgresql://USER:PASSWORD@HOST.SUPABASE_PROJECT_ID.supabase.co:6543/postgres
# For Neon: postgresql://USER:PASSWORD@ep-xyz.us-east-1.aws.neon.tech/saferoute?sslmode=require
# DATABASE_URL="file:./dev.db"

# JWT Secrets - CHANGE IN PRODUCTION!
# JWT_SECRET="saferoute-super-secret-key-change-in-production"
# JWT_REFRESH_SECRET="saferoute-refresh-secret-change-in-production"

# API Keys
GEMINI_API_KEY=""
OPENWEATHER_API_KEY=""

# Server Configuration
# NODE_ENV="development"
# PORT=3000
# CORS_ORIGIN="http://localhost:5173"

# Vite API URL (for frontend API calls)
VITE_API_URL=""
